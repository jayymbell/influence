{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build:coverage": "cross-env VITE_COVERAGE=true vite build",
    "preview:coverage": "vite preview --port 5173",
    "e2e:coverage": "yarn build:coverage && yarn preview:coverage & npx playwright test",
    "install:playwright": "npx playwright install --with-deps",
    "dev:coverage": "cross-env VITE_COVERAGE=true vite",
    "e2e:coverage-dev": "yarn dev:coverage & npx playwright test --config=playwright/playwright.config.cjs",
    "coverage:merge": "npx nyc merge coverage coverage/playwright-merged.json && npx nyc report --reporter=html --reporter=lcov --reporter=text --temp-dir=coverage --report-dir=coverage/lcov-report",
    "test:all": "yarn test:coverage && yarn e2e:coverage-dev && yarn coverage:merge"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.12.0",
    "lodash": "^4.17.23",
    "pinia": "^3.0.3",
    "vite-plugin-vuetify": "^2.1.2",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "vite": "^8.0.1",
    "vite-plugin-istanbul": "^8.0.0",
    "cross-env": "^10.1.0",
    "@babel/core": "^7.22.9",
    "@babel/preset-env": "^7.29.2",
    "@playwright/test": "^1.40.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/vue3-jest": "^29.0.3",
    "babel-jest": "^30.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "nyc": "^18.0.0"
  }
}
